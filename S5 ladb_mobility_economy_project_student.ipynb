    "# Limpia separadores y convierte columnas numéricas en eco\n",
    "eco['city_gdp/capita'] = (\n",
    "    eco['city_gdp/capita']\n",
    "    .astype(str)\n",
    "    .str.replace('.', '', regex=False)\n",
    "    .str.replace(',', '.', regex=False)\n",
    "    .astype(float)\n",
    ")\n",
    "\n",
    "# Limpiar y convertir unemployment_%\n",
    "eco['unemployment_%'] = (\n",
    "    eco['unemployment_%']\n",
    "    .astype(str)\n",
    "    .str.replace('%', '', regex=False)\n",
    "    .str.replace(',', '.', regex=False)\n",
    "    .astype(float)\n",
    ")\n",
    "\n",
    "# Limpiar y convertir population_(m)\n",
    "eco['population_(m)'] = (\n",
    "    eco['population_(m)']\n",
    "    .astype(str)\n",
    "    .str.replace(',', '.', regex=False)\n",
    "    .astype(float)\n",
    ")\n",
    "\n",
    "# Crear columna de población total\n",
    "eco['population'] = eco['population_(m)'] * 1000000\n",
    "\n",
    "# Verificar cambios\n",
    "eco.info()\n",
    "eco.head(3)\n"
   ]
