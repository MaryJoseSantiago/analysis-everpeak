    "        'city_gdp/capita',\n",
    "        'unemployment_%',\n",
    "        'pm2.5_(μg/m³)',\n",
    "        'population'\n",
    "    ]\n",
    "].copy()\n",
    "\n",
    "# Unir datasets\n",
    "merged = traffic_2024_small.merge(\n",
    "    eco_2024_small,\n",
