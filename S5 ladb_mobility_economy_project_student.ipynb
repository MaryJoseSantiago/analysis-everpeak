    "# Seleccionar columnas clave de tráfico\n",
    "traffic_2024_small = traffic_city_year_2024[\n",
    "    [\n",
    "        'City',\n",
    "        'country',\n",
    "        'year',\n",
    "        'JamsDelay',\n",
