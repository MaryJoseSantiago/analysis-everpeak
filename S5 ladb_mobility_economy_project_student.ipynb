    "        'JamsLengthInKms',\n",
    "        'JamsCount',\n",
    "        'MinsDelay',\n",
    "        'TravelTimeLivePer10KmsMins',\n",
    "        'TravelTimeHistoricPer10KmsMins'\n",
    "    ]\n",
    "].copy()\n",
    "\n",
    "# Seleccionar columnas clave de economía\n",
    "eco_2024_small = eco_2024[\n",
    "    [\n",
    "        'city',\n",
    "        'year',\n",
    "        'city_gdp/capita',\n",
    "        'unemployment_%',\n",
    "        'population'\n",
    "    ]\n",
    "].copy()\n",
    "\n",
    "# Unir datasets manteniendo solo coincidencias\n",
    "merged = traffic_2024_small.merge(\n",
    "    eco_2024_small,\n",
    "    left_on=['City', 'year'],\n",
    "    right_on=['city', 'year'],\n",
    "    how='inner'\n",
    ")\n",
    "\n",
    "# Mostrar las primeras 5 filas\n",
    "merged.head()"
